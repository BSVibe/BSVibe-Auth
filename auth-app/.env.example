# BSVibe-Auth (Next.js 15)
#
# Phase Z migration note: env vars renamed from VITE_* to NEXT_PUBLIC_* for
# client-exposed values. Server-only secrets (service role key, signing
# secret) have no prefix and are NEVER inlined into the client bundle.

# Public — inlined into the client bundle at build time.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_ALLOWED_REDIRECT_ORIGINS=http://localhost:5179,http://localhost:8000

# Server-only — used by Route Handlers (app/api/*) and never exposed to the client.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ALLOWED_REDIRECT_ORIGINS=http://localhost:5179,http://localhost:8000

# Service token (P0.7) — HS256 shared secret + issuer URL.
SERVICE_TOKEN_SIGNING_SECRET=
SERVICE_TOKEN_ISSUER=https://auth.bsvibe.dev
